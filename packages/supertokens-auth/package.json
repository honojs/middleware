{
  "name": "@hono/supertokens",
  "version": "0.1.0",
  "description": "SuperTokens authentication middleware for Hono",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "hono",
    "middleware",
    "supertokens",
    "auth",
    "authentication",
    "session"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "hono": ">=4.0.0",
    "supertokens-node": ">=17.0.0"
  },
  "devDependencies": {
    "hono": "^4.12.18",
    "supertokens-node": "^21.1.2",
    "tsdown": "^0.12.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  }
}
