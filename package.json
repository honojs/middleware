{
  "name": "hono-middleware",
  "version": "0.0.0",
  "description": "Third-party middleware for Hono",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "build:pkg": "tsdown --workspace $INIT_CWD",
    "publish": "pnpm publish:npm && pnpm publish:jsr",
    "publish:npm": "pnpm -r publish --no-git-checks && changeset tag",
    "publish:jsr": "deno install --no-lock && deno publish",
    "version": "pnpm version:npm && pnpm version:jsr",
    "version:npm": "changeset version",
    "version:jsr": "turbo run version:jsr",
    "version:set": "node scripts/version-set.ts",
    "typecheck": "tsc --build",
    "typecheck:clean": "tsc --build --clean",
    "typecheck:watch": "tsc --build --watch",
    "test": "vitest",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "format": "prettier --check . --cache --cache-location .cache/.prettiercache",
    "format:fix": "prettier --write . --cache --cache-location .cache/.prettiercache"
  },
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/honojs/middleware.git"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.29.7",
    "@cloudflare/vitest-pool-workers": "^0.16.10",
    "@cloudflare/workers-types": "^4.20250612.0",
    "@hono/eslint-config": "workspace:*",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.2.3",
    "@typia/unplugin": "^12.1.1",
    "@vitest/coverage-istanbul": "^4.1.8",
    "eslint": "^10.0.3",
    "hono": "^4.11.5",
    "pkg-pr-new": "^0.0.78",
    "prettier": "^3.8.1",
    "publint": "^0.3.16",
    "tsdown": "^0.22.3",
    "turbo": "^2.9.4",
    "typescript": "^6.0.3",
    "typia": "^12.1.1",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@11.9.0"
}
